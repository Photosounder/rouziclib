#ifdef RL_VULKAN

#include "../graphics/drawqueue/vulkan/drawqueue.comp.spv.h"

typedef struct
{
	int32_t width;
	int32_t height;
	int32_t sector_width;
	int32_t sector_size;
	uint32_t random_seed;
} vk_drawq_constants_t;

const char *get_vk_error_string(VkResult err)
{
	// Return names for core and swapchain results used by this backend
	switch (err)
	{
		case VK_SUCCESS: return "VK_SUCCESS";
		case VK_NOT_READY: return "VK_NOT_READY";
		case VK_TIMEOUT: return "VK_TIMEOUT";
		case VK_EVENT_SET: return "VK_EVENT_SET";
		case VK_EVENT_RESET: return "VK_EVENT_RESET";
		case VK_INCOMPLETE: return "VK_INCOMPLETE";
		case VK_ERROR_OUT_OF_HOST_MEMORY: return "VK_ERROR_OUT_OF_HOST_MEMORY";
		case VK_ERROR_OUT_OF_DEVICE_MEMORY: return "VK_ERROR_OUT_OF_DEVICE_MEMORY";
		case VK_ERROR_INITIALIZATION_FAILED: return "VK_ERROR_INITIALIZATION_FAILED";
		case VK_ERROR_DEVICE_LOST: return "VK_ERROR_DEVICE_LOST";
		case VK_ERROR_MEMORY_MAP_FAILED: return "VK_ERROR_MEMORY_MAP_FAILED";
		case VK_ERROR_LAYER_NOT_PRESENT: return "VK_ERROR_LAYER_NOT_PRESENT";
		case VK_ERROR_EXTENSION_NOT_PRESENT: return "VK_ERROR_EXTENSION_NOT_PRESENT";
		case VK_ERROR_FEATURE_NOT_PRESENT: return "VK_ERROR_FEATURE_NOT_PRESENT";
		case VK_ERROR_INCOMPATIBLE_DRIVER: return "VK_ERROR_INCOMPATIBLE_DRIVER";
		case VK_ERROR_TOO_MANY_OBJECTS: return "VK_ERROR_TOO_MANY_OBJECTS";
		case VK_ERROR_FORMAT_NOT_SUPPORTED: return "VK_ERROR_FORMAT_NOT_SUPPORTED";
		case VK_ERROR_FRAGMENTED_POOL: return "VK_ERROR_FRAGMENTED_POOL";
		case VK_ERROR_SURFACE_LOST_KHR: return "VK_ERROR_SURFACE_LOST_KHR";
		case VK_ERROR_NATIVE_WINDOW_IN_USE_KHR: return "VK_ERROR_NATIVE_WINDOW_IN_USE_KHR";
		case VK_SUBOPTIMAL_KHR: return "VK_SUBOPTIMAL_KHR";
		case VK_ERROR_OUT_OF_DATE_KHR: return "VK_ERROR_OUT_OF_DATE_KHR";
		default: return "Unknown Vulkan error";
	}
}

static uint32_t vk_find_memory_type(uint32_t type_bits, VkMemoryPropertyFlags properties)
{
	VkPhysicalDeviceMemoryProperties memory_properties;

	// Find the first compatible heap exposing every requested property
	vkGetPhysicalDeviceMemoryProperties(fb->vk.gpu, &memory_properties);
	for (uint32_t i=0; i < memory_properties.memoryTypeCount; i++)
		if ((type_bits & (1u << i)) && (memory_properties.memoryTypes[i].propertyFlags & properties)==properties)
			return i;

	return UINT32_MAX;
}

static void vk_destroy_buffer(vk_buffer_t *buffer)
{
	// Release a mapped buffer and clear all ownership state
	if (buffer->mapped && buffer->memory)
		vkUnmapMemory(fb->vk.device, buffer->memory);
	if (buffer->buffer)
		vkDestroyBuffer(fb->vk.device, buffer->buffer, NULL);
	if (buffer->memory)
		vkFreeMemory(fb->vk.device, buffer->memory, NULL);
	memset(buffer, 0, sizeof(*buffer));
}

static VkResult vk_create_buffer(vk_buffer_t *buffer, VkDeviceSize size, VkBufferUsageFlags usage, VkMemoryPropertyFlags properties, int map)
{
	VkResult ret;
	VkMemoryRequirements requirements;
	uint32_t memory_type;
	VkBufferCreateInfo buffer_info = { .sType=VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO, .size=MAXN(size, 4), .usage=usage, .sharingMode=VK_SHARING_MODE_EXCLUSIVE };

	// Create the buffer before selecting memory compatible with its requirements
	memset(buffer, 0, sizeof(*buffer));
	ret = vkCreateBuffer(fb->vk.device, &buffer_info, NULL, &buffer->buffer);
	VK_ERR_RET("vkCreateBuffer", ret);
	vkGetBufferMemoryRequirements(fb->vk.device, buffer->buffer, &requirements);
	memory_type = vk_find_memory_type(requirements.memoryTypeBits, properties);
	if (memory_type==UINT32_MAX)
	{
		fprintf_rl(stderr, "No Vulkan memory type supports buffer properties 0x%x\n", properties);
		vk_destroy_buffer(buffer);
		return VK_ERROR_FEATURE_NOT_PRESENT;
	}

	// Allocate and bind the selected memory type
	VkMemoryAllocateInfo allocation_info = { .sType=VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO, .allocationSize=requirements.size, .memoryTypeIndex=memory_type };
	ret = vkAllocateMemory(fb->vk.device, &allocation_info, NULL, &buffer->memory);
	if (ret != VK_SUCCESS)
	{
		vk_destroy_buffer(buffer);
		return ret;
	}
	ret = vkBindBufferMemory(fb->vk.device, buffer->buffer, buffer->memory, 0);
	if (ret != VK_SUCCESS)
	{
		vk_destroy_buffer(buffer);
		return ret;
	}
	buffer->capacity = MAXN(size, 4);

	// Persistently map upload and queue buffers requested by the caller
	if (map)
	{
		ret = vkMapMemory(fb->vk.device, buffer->memory, 0, VK_WHOLE_SIZE, 0, &buffer->mapped);
		if (ret != VK_SUCCESS)
		{
			vk_destroy_buffer(buffer);
			return ret;
		}
	}

	return VK_SUCCESS;
}

static VkResult vk_ensure_host_buffer(vk_buffer_t *buffer, VkDeviceSize required, VkBufferUsageFlags usage)
{
	VkDeviceSize capacity=4096;

	// Keep a reusable mapped allocation when it already fits this frame
	if (buffer->capacity >= MAXN(required, 4))
		return VK_SUCCESS;
	while (capacity < required)
		capacity <<= 1;
	vk_destroy_buffer(buffer);
	return vk_create_buffer(buffer, capacity, usage, VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT | VK_MEMORY_PROPERTY_HOST_COHERENT_BIT, 1);
}

static int vk_device_has_swapchain(VkPhysicalDevice device)
{
	uint32_t extension_count=0;
	VkExtensionProperties *extensions;
	int found=0;

	// Enumerate device extensions and require the swapchain implementation
	vkEnumerateDeviceExtensionProperties(device, NULL, &extension_count, NULL);
	extensions = calloc(extension_count, sizeof(*extensions));
	vkEnumerateDeviceExtensionProperties(device, NULL, &extension_count, extensions);
	for (uint32_t i=0; i < extension_count; i++)
		if (strcmp(extensions[i].extensionName, VK_KHR_SWAPCHAIN_EXTENSION_NAME)==0)
			found=1;
	free(extensions);
	return found;
}

static int vk_find_device_queue(VkPhysicalDevice device, uint32_t *queue_family, uint32_t *timestamp_valid_bits)
{
	uint32_t family_count=0;
	VkQueueFamilyProperties *families;
	int found=0;

	// Find one queue family that can compute, blit, and present
	vkGetPhysicalDeviceQueueFamilyProperties(device, &family_count, NULL);
	families = calloc(family_count, sizeof(*families));
	vkGetPhysicalDeviceQueueFamilyProperties(device, &family_count, families);
	for (uint32_t i=0; i < family_count && !found; i++)
	{
		VkBool32 present=VK_FALSE;
		VkQueueFlags required=VK_QUEUE_GRAPHICS_BIT | VK_QUEUE_COMPUTE_BIT;
		vkGetPhysicalDeviceSurfaceSupportKHR(device, i, fb->vk.surface, &present);
		if ((families[i].queueFlags & required)==required && present)
		{
			*queue_family=i;
			// Return the timestamp width belonging to the selected queue
			*timestamp_valid_bits=families[i].timestampValidBits;
			found=1;
		}
	}
	free(families);
	return found;
}

static VkResult vk_create_instance_surface()
{
	VkResult ret;
	unsigned extension_count=0;
	const char **extensions;

	// Ask SDL for the platform surface extensions required by this window
	if (!SDL_Vulkan_GetInstanceExtensions(fb->window, &extension_count, NULL))
	{
		fprintf_rl(stderr, "SDL_Vulkan_GetInstanceExtensions failed: %s\n", SDL_GetError());
		return VK_ERROR_EXTENSION_NOT_PRESENT;
	}
	extensions = calloc(extension_count, sizeof(*extensions));
	if (!SDL_Vulkan_GetInstanceExtensions(fb->window, &extension_count, extensions))
	{
		fprintf_rl(stderr, "SDL_Vulkan_GetInstanceExtensions failed: %s\n", SDL_GetError());
		free(extensions);
		return VK_ERROR_EXTENSION_NOT_PRESENT;
	}

	// Create a Vulkan 1.1 instance without requiring optional validation layers
	VkApplicationInfo application_info = { .sType=VK_STRUCTURE_TYPE_APPLICATION_INFO, .pApplicationName="rouziclib", .apiVersion=VK_API_VERSION_1_1 };
	VkInstanceCreateInfo instance_info = { .sType=VK_STRUCTURE_TYPE_INSTANCE_CREATE_INFO, .pApplicationInfo=&application_info, .enabledExtensionCount=extension_count, .ppEnabledExtensionNames=extensions };
	ret = vkCreateInstance(&instance_info, NULL, &fb->vk.instance);
	free(extensions);
	VK_ERR_RET("vkCreateInstance", ret);

	// Create the SDL surface before choosing a presentation-capable device
	if (!SDL_Vulkan_CreateSurface(fb->window, fb->vk.instance, &fb->vk.surface))
	{
		fprintf_rl(stderr, "SDL_Vulkan_CreateSurface failed: %s\n", SDL_GetError());
		return VK_ERROR_SURFACE_LOST_KHR;
	}

	return VK_SUCCESS;
}

static VkResult vk_select_device()
{
	VkResult ret;
	uint32_t device_count=0;
	VkPhysicalDevice *devices;
	int best_score=-1;

	// Enumerate devices and score only complete compute and presentation candidates
	ret = vkEnumeratePhysicalDevices(fb->vk.instance, &device_count, NULL);
	VK_ERR_RET("vkEnumeratePhysicalDevices", ret);
	if (device_count==0)
		return VK_ERROR_INCOMPATIBLE_DRIVER;
	devices = calloc(device_count, sizeof(*devices));
	vkEnumeratePhysicalDevices(fb->vk.instance, &device_count, devices);
	for (uint32_t i=0; i < device_count; i++)
	{
		uint32_t queue_family;
		uint32_t timestamp_valid_bits;
		VkPhysicalDeviceProperties properties;
		if (!vk_device_has_swapchain(devices[i]) || !vk_find_device_queue(devices[i], &queue_family, &timestamp_valid_bits))
			continue;
		vkGetPhysicalDeviceProperties(devices[i], &properties);
		int score = properties.deviceType==VK_PHYSICAL_DEVICE_TYPE_DISCRETE_GPU ? 1000 : 0;
		score += (int) properties.limits.maxImageDimension2D;
		if (score > best_score)
		{
			best_score=score;
			fb->vk.gpu=devices[i];
			fb->vk.queue_family=queue_family;
			fb->vk.timestamp_valid_bits=timestamp_valid_bits;
			fb->vk.timestamp_period=properties.limits.timestampPeriod;
		}
	}
	free(devices);
	if (!fb->vk.gpu)
		return VK_ERROR_FEATURE_NOT_PRESENT;

	// Create one ordered queue shared by compute, transfers, and presentation
	float priority=1.f;
	const char *extensions[] = { VK_KHR_SWAPCHAIN_EXTENSION_NAME };
	VkDeviceQueueCreateInfo queue_info = { .sType=VK_STRUCTURE_TYPE_DEVICE_QUEUE_CREATE_INFO, .queueFamilyIndex=fb->vk.queue_family, .queueCount=1, .pQueuePriorities=&priority };
	VkDeviceCreateInfo device_info = { .sType=VK_STRUCTURE_TYPE_DEVICE_CREATE_INFO, .queueCreateInfoCount=1, .pQueueCreateInfos=&queue_info, .enabledExtensionCount=1, .ppEnabledExtensionNames=extensions };
	ret = vkCreateDevice(fb->vk.gpu, &device_info, NULL, &fb->vk.device);
	VK_ERR_RET("vkCreateDevice", ret);
	vkGetDeviceQueue(fb->vk.device, fb->vk.queue_family, 0, &fb->vk.queue);

	// Allocate resettable command buffers from one family-owned pool
	VkCommandPoolCreateInfo pool_info = { .sType=VK_STRUCTURE_TYPE_COMMAND_POOL_CREATE_INFO, .queueFamilyIndex=fb->vk.queue_family, .flags=VK_COMMAND_POOL_CREATE_RESET_COMMAND_BUFFER_BIT };
	ret = vkCreateCommandPool(fb->vk.device, &pool_info, NULL, &fb->vk.command_pool);
	VK_ERR_RET("vkCreateCommandPool", ret);

	return VK_SUCCESS;
}

static void vk_destroy_swapchain()
{
	// Release swapchain images before destroying the presentation chain
	free_null(&fb->vk.swapchain_images);
	if (fb->vk.swapchain)
		vkDestroySwapchainKHR(fb->vk.device, fb->vk.swapchain, NULL);
	fb->vk.swapchain=VK_NULL_HANDLE;
	fb->vk.swapchain_image_count=0;
}

static VkResult vk_create_swapchain()
{
	VkResult ret;
	VkSurfaceCapabilitiesKHR capabilities;
	uint32_t format_count=0;
	VkSurfaceFormatKHR *formats;
	VkSurfaceFormatKHR selected_format;
	VkCompositeAlphaFlagBitsKHR composite_alpha=VK_COMPOSITE_ALPHA_OPAQUE_BIT_KHR;
	int drawable_width, drawable_height;

	// Query the current surface and reject presentation paths without transfer destinations
	ret = vkGetPhysicalDeviceSurfaceCapabilitiesKHR(fb->vk.gpu, fb->vk.surface, &capabilities);
	VK_ERR_RET("vkGetPhysicalDeviceSurfaceCapabilitiesKHR", ret);
	if (!(capabilities.supportedUsageFlags & VK_IMAGE_USAGE_TRANSFER_DST_BIT))
		return VK_ERROR_FORMAT_NOT_SUPPORTED;
	vkGetPhysicalDeviceSurfaceFormatsKHR(fb->vk.gpu, fb->vk.surface, &format_count, NULL);
	if (format_count==0)
		return VK_ERROR_FORMAT_NOT_SUPPORTED;
	formats = calloc(format_count, sizeof(*formats));
	vkGetPhysicalDeviceSurfaceFormatsKHR(fb->vk.gpu, fb->vk.surface, &format_count, formats);
	selected_format=formats[0];
	// Choose a concrete preferred format when the surface reports no restriction
	if (format_count==1 && selected_format.format==VK_FORMAT_UNDEFINED)
	{
		selected_format.format=VK_FORMAT_B8G8R8A8_UNORM;
		selected_format.colorSpace=VK_COLOR_SPACE_SRGB_NONLINEAR_KHR;
	}
	for (uint32_t i=0; i < format_count; i++)
		if ((formats[i].format==VK_FORMAT_B8G8R8A8_UNORM || formats[i].format==VK_FORMAT_R8G8B8A8_UNORM) && formats[i].colorSpace==VK_COLOR_SPACE_SRGB_NONLINEAR_KHR)
		{
			selected_format=formats[i];
			break;
		}
	free(formats);

	// Select the drawable extent reported by SDL when the surface leaves it variable
	if (capabilities.currentExtent.width != UINT32_MAX)
		fb->vk.swapchain_extent=capabilities.currentExtent;
	else
	{
		SDL_Vulkan_GetDrawableSize(fb->window, &drawable_width, &drawable_height);
		if (drawable_width<=0 || drawable_height<=0)
			return VK_NOT_READY;
		fb->vk.swapchain_extent.width=rangelimit(drawable_width, capabilities.minImageExtent.width, capabilities.maxImageExtent.width);
		fb->vk.swapchain_extent.height=rangelimit(drawable_height, capabilities.minImageExtent.height, capabilities.maxImageExtent.height);
	}
	if (fb->vk.swapchain_extent.width==0 || fb->vk.swapchain_extent.height==0)
		return VK_NOT_READY;

	// Choose a supported opaque composite mode and FIFO presentation for guaranteed vsync
	if (!(capabilities.supportedCompositeAlpha & composite_alpha))
		for (uint32_t bit=0; bit < 4; bit++)
			if (capabilities.supportedCompositeAlpha & (1u << bit))
			{
				composite_alpha=(VkCompositeAlphaFlagBitsKHR) (1u << bit);
				break;
			}
	uint32_t image_count=capabilities.minImageCount+1;
	if (capabilities.maxImageCount && image_count > capabilities.maxImageCount)
		image_count=capabilities.maxImageCount;

	// Replace the old chain only after all previous submissions have completed
	vk_destroy_swapchain();
	VkSwapchainCreateInfoKHR swapchain_info = { .sType=VK_STRUCTURE_TYPE_SWAPCHAIN_CREATE_INFO_KHR, .surface=fb->vk.surface, .minImageCount=image_count, .imageFormat=selected_format.format, .imageColorSpace=selected_format.colorSpace, .imageExtent=fb->vk.swapchain_extent, .imageArrayLayers=1, .imageUsage=VK_IMAGE_USAGE_TRANSFER_DST_BIT, .imageSharingMode=VK_SHARING_MODE_EXCLUSIVE, .preTransform=capabilities.currentTransform, .compositeAlpha=composite_alpha, .presentMode=VK_PRESENT_MODE_FIFO_KHR, .clipped=VK_TRUE };
	ret = vkCreateSwapchainKHR(fb->vk.device, &swapchain_info, NULL, &fb->vk.swapchain);
	VK_ERR_RET("vkCreateSwapchainKHR", ret);
	fb->vk.swapchain_format=selected_format.format;
	vkGetSwapchainImagesKHR(fb->vk.device, fb->vk.swapchain, &fb->vk.swapchain_image_count, NULL);
	fb->vk.swapchain_images=calloc(fb->vk.swapchain_image_count, sizeof(*fb->vk.swapchain_images));
	vkGetSwapchainImagesKHR(fb->vk.device, fb->vk.swapchain, &fb->vk.swapchain_image_count, fb->vk.swapchain_images);
	fb->vk.swapchain_dirty=0;

	return VK_SUCCESS;
}

static VkResult vk_create_output_image(vk_frame_t *frame)
{
	VkResult ret;
	VkMemoryRequirements requirements;
	uint32_t memory_type;

	// Create one compute output image for this independently reusable frame slot
	VkImageCreateInfo image_info = { .sType=VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO, .imageType=VK_IMAGE_TYPE_2D, .format=VK_FORMAT_R8G8B8A8_UNORM, .extent={fb->maxdim.x, fb->maxdim.y, 1}, .mipLevels=1, .arrayLayers=1, .samples=VK_SAMPLE_COUNT_1_BIT, .tiling=VK_IMAGE_TILING_OPTIMAL, .usage=VK_IMAGE_USAGE_STORAGE_BIT | VK_IMAGE_USAGE_TRANSFER_SRC_BIT, .sharingMode=VK_SHARING_MODE_EXCLUSIVE, .initialLayout=VK_IMAGE_LAYOUT_UNDEFINED };
	ret = vkCreateImage(fb->vk.device, &image_info, NULL, &frame->output_image);
	VK_ERR_RET("vkCreateImage", ret);
	vkGetImageMemoryRequirements(fb->vk.device, frame->output_image, &requirements);
	memory_type=vk_find_memory_type(requirements.memoryTypeBits, VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT);
	if (memory_type==UINT32_MAX)
		return VK_ERROR_FEATURE_NOT_PRESENT;

	// Allocate and bind device-local image memory
	VkMemoryAllocateInfo allocation_info = { .sType=VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO, .allocationSize=requirements.size, .memoryTypeIndex=memory_type };
	ret = vkAllocateMemory(fb->vk.device, &allocation_info, NULL, &frame->output_memory);
	VK_ERR_RET("vkAllocateMemory", ret);
	ret = vkBindImageMemory(fb->vk.device, frame->output_image, frame->output_memory, 0);
	VK_ERR_RET("vkBindImageMemory", ret);

	// Expose the image to the compute descriptor set
	VkImageViewCreateInfo view_info = { .sType=VK_STRUCTURE_TYPE_IMAGE_VIEW_CREATE_INFO, .image=frame->output_image, .viewType=VK_IMAGE_VIEW_TYPE_2D, .format=VK_FORMAT_R8G8B8A8_UNORM, .subresourceRange={VK_IMAGE_ASPECT_COLOR_BIT, 0, 1, 0, 1} };
	ret = vkCreateImageView(fb->vk.device, &view_info, NULL, &frame->output_view);
	VK_ERR_RET("vkCreateImageView", ret);

	return VK_SUCCESS;
}

static VkResult vk_create_pipeline()
{
	VkResult ret;
	VkShaderModule shader_module;
	VkDescriptorSetLayoutBinding bindings[5];

	// Describe four storage buffers and one storage image used by the compute shader
	memset(bindings, 0, sizeof(bindings));
	for (uint32_t i=0; i < 4; i++)
	{
		bindings[i].binding=i;
		bindings[i].descriptorType=VK_DESCRIPTOR_TYPE_STORAGE_BUFFER;
		bindings[i].descriptorCount=1;
		bindings[i].stageFlags=VK_SHADER_STAGE_COMPUTE_BIT;
	}
	bindings[4].binding=4;
	bindings[4].descriptorType=VK_DESCRIPTOR_TYPE_STORAGE_IMAGE;
	bindings[4].descriptorCount=1;
	bindings[4].stageFlags=VK_SHADER_STAGE_COMPUTE_BIT;
	VkDescriptorSetLayoutCreateInfo layout_info = { .sType=VK_STRUCTURE_TYPE_DESCRIPTOR_SET_LAYOUT_CREATE_INFO, .bindingCount=5, .pBindings=bindings };
	ret = vkCreateDescriptorSetLayout(fb->vk.device, &layout_info, NULL, &fb->vk.descriptor_layout);
	VK_ERR_RET("vkCreateDescriptorSetLayout", ret);

	// Create the pipeline layout with compact per-frame dimensions and seed constants
	VkPushConstantRange push_range = { .stageFlags=VK_SHADER_STAGE_COMPUTE_BIT, .offset=0, .size=sizeof(vk_drawq_constants_t) };
	VkPipelineLayoutCreateInfo pipeline_layout_info = { .sType=VK_STRUCTURE_TYPE_PIPELINE_LAYOUT_CREATE_INFO, .setLayoutCount=1, .pSetLayouts=&fb->vk.descriptor_layout, .pushConstantRangeCount=1, .pPushConstantRanges=&push_range };
	ret = vkCreatePipelineLayout(fb->vk.device, &pipeline_layout_info, NULL, &fb->vk.pipeline_layout);
	VK_ERR_RET("vkCreatePipelineLayout", ret);

	// Load the validated embedded SPIR-V and create the compute pipeline
	VkShaderModuleCreateInfo shader_info = { .sType=VK_STRUCTURE_TYPE_SHADER_MODULE_CREATE_INFO, .codeSize=vk_drawqueue_comp_spv_size, .pCode=vk_drawqueue_comp_spv };
	ret = vkCreateShaderModule(fb->vk.device, &shader_info, NULL, &shader_module);
	VK_ERR_RET("vkCreateShaderModule", ret);
	VkPipelineShaderStageCreateInfo stage_info = { .sType=VK_STRUCTURE_TYPE_PIPELINE_SHADER_STAGE_CREATE_INFO, .stage=VK_SHADER_STAGE_COMPUTE_BIT, .module=shader_module, .pName="main" };
	VkComputePipelineCreateInfo pipeline_info = { .sType=VK_STRUCTURE_TYPE_COMPUTE_PIPELINE_CREATE_INFO, .stage=stage_info, .layout=fb->vk.pipeline_layout };
	ret = vkCreateComputePipelines(fb->vk.device, VK_NULL_HANDLE, 1, &pipeline_info, NULL, &fb->vk.compute_pipeline);
	vkDestroyShaderModule(fb->vk.device, shader_module, NULL);
	VK_ERR_RET("vkCreateComputePipelines", ret);

	// Allocate enough descriptors for every in-flight output image
	VkDescriptorPoolSize pool_sizes[2] = {
		{ VK_DESCRIPTOR_TYPE_STORAGE_BUFFER, 4*RL_VK_FRAMES_IN_FLIGHT },
		{ VK_DESCRIPTOR_TYPE_STORAGE_IMAGE, RL_VK_FRAMES_IN_FLIGHT }
	};
	VkDescriptorPoolCreateInfo pool_info = { .sType=VK_STRUCTURE_TYPE_DESCRIPTOR_POOL_CREATE_INFO, .maxSets=RL_VK_FRAMES_IN_FLIGHT, .poolSizeCount=2, .pPoolSizes=pool_sizes };
	ret = vkCreateDescriptorPool(fb->vk.device, &pool_info, NULL, &fb->vk.descriptor_pool);
	VK_ERR_RET("vkCreateDescriptorPool", ret);

	return VK_SUCCESS;
}

static VkResult vk_create_frames()
{
	VkResult ret;
	VkCommandBuffer command_buffers[RL_VK_FRAMES_IN_FLIGHT];
	VkDescriptorSetLayout layouts[RL_VK_FRAMES_IN_FLIGHT];
	VkDescriptorSet descriptor_sets[RL_VK_FRAMES_IN_FLIGHT];

	// Allocate one primary command buffer for each reusable frame slot
	VkCommandBufferAllocateInfo command_info = { .sType=VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO, .commandPool=fb->vk.command_pool, .level=VK_COMMAND_BUFFER_LEVEL_PRIMARY, .commandBufferCount=RL_VK_FRAMES_IN_FLIGHT };
	ret = vkAllocateCommandBuffers(fb->vk.device, &command_info, command_buffers);
	VK_ERR_RET("vkAllocateCommandBuffers", ret);

	// Allocate one descriptor set per output image
	for (int i=0; i < RL_VK_FRAMES_IN_FLIGHT; i++)
		layouts[i]=fb->vk.descriptor_layout;
	VkDescriptorSetAllocateInfo descriptor_info = { .sType=VK_STRUCTURE_TYPE_DESCRIPTOR_SET_ALLOCATE_INFO, .descriptorPool=fb->vk.descriptor_pool, .descriptorSetCount=RL_VK_FRAMES_IN_FLIGHT, .pSetLayouts=layouts };
	ret = vkAllocateDescriptorSets(fb->vk.device, &descriptor_info, descriptor_sets);
	VK_ERR_RET("vkAllocateDescriptorSets", ret);

	for (int i=0; i < RL_VK_FRAMES_IN_FLIGHT; i++)
	{
		vk_frame_t *frame=&fb->vk.frame[i];
		frame->command_buffer=command_buffers[i];
		frame->descriptor_set=descriptor_sets[i];

		// Create signalled fences and binary swapchain semaphores for initial reuse
		VkFenceCreateInfo fence_info = { .sType=VK_STRUCTURE_TYPE_FENCE_CREATE_INFO, .flags=VK_FENCE_CREATE_SIGNALED_BIT };
		VkSemaphoreCreateInfo semaphore_info = { .sType=VK_STRUCTURE_TYPE_SEMAPHORE_CREATE_INFO };
		ret = vkCreateFence(fb->vk.device, &fence_info, NULL, &frame->fence);
		VK_ERR_RET("vkCreateFence", ret);
		ret = vkCreateSemaphore(fb->vk.device, &semaphore_info, NULL, &frame->image_available);
		VK_ERR_RET("vkCreateSemaphore", ret);
		ret = vkCreateSemaphore(fb->vk.device, &semaphore_info, NULL, &frame->render_finished);
		VK_ERR_RET("vkCreateSemaphore", ret);

		// Create one timestamp pool for compute and blit boundaries when the queue supports it
		if (fb->vk.timestamp_valid_bits)
		{
			VkQueryPoolCreateInfo query_info = { .sType=VK_STRUCTURE_TYPE_QUERY_POOL_CREATE_INFO, .queryType=VK_QUERY_TYPE_TIMESTAMP, .queryCount=2 };
			ret = vkCreateQueryPool(fb->vk.device, &query_info, NULL, &frame->timestamp_pool);
			VK_ERR_RET("vkCreateQueryPool", ret);
		}

		// Give each slot a private compute destination so two frames can overlap
		ret = vk_create_output_image(frame);
		VK_ERR_RET("vk_create_output_image", ret);
	}

	return VK_SUCCESS;
}

void vk_wait_idle()
{
	// Wait only when a valid logical device owns submissions
	if (fb->vk.device)
		vkDeviceWaitIdle(fb->vk.device);
}

int vk_data_buffer_resize(size_t size)
{
	VkResult ret;
	vk_buffer_t replacement;

	// Recreate the device-local arena after all readers have stopped
	if (!fb->vk.device)
		return 0;
	vkDeviceWaitIdle(fb->vk.device);
	ret = vk_create_buffer(&replacement, MAXN(size, 4), VK_BUFFER_USAGE_STORAGE_BUFFER_BIT | VK_BUFFER_USAGE_TRANSFER_DST_BIT, VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT, 0);
	if (ret != VK_SUCCESS)
	{
		fprintf_rl(stderr, "vk_data_buffer_resize() failed: %s\n", get_vk_error_string(ret));
		return 0;
	}
	vk_destroy_buffer(&fb->vk.resource_data);
	fb->vk.resource_data=replacement;
	fb->vk.dirty_start=0;
	fb->vk.dirty_end=size;
	return 1;
}

void vk_data_buffer_free()
{
	// Stop resource readers before releasing the packed device arena
	if (fb->vk.device)
		vkDeviceWaitIdle(fb->vk.device);
	vk_destroy_buffer(&fb->vk.resource_data);
	fb->vk.dirty_start=SIZE_MAX;
	fb->vk.dirty_end=0;
}

void vk_mark_data_dirty(size_t offset, size_t size)
{
	// Merge resource changes into one upload interval for the next dispatch
	if (size==0)
		return;
	if (fb->vk.dirty_start==SIZE_MAX || offset < fb->vk.dirty_start)
		fb->vk.dirty_start=offset;
	if (offset+size > fb->vk.dirty_end)
		fb->vk.dirty_end=offset+size;
}

void vk_mark_swapchain_dirty()
{
	// Request lazy recreation after resize or presentation invalidation
	fb->vk.swapchain_dirty=1;
}

static void vk_update_descriptors(vk_frame_t *frame)
{
	VkDescriptorBufferInfo buffer_info[4] = {
		{ frame->drawq.buffer, 0, VK_WHOLE_SIZE },
		{ frame->sector_pos.buffer, 0, VK_WHOLE_SIZE },
		{ frame->entry_list.buffer, 0, VK_WHOLE_SIZE },
		{ fb->vk.resource_data.buffer, 0, VK_WHOLE_SIZE }
	};
	VkDescriptorImageInfo image_info = { .imageView=frame->output_view, .imageLayout=VK_IMAGE_LAYOUT_GENERAL };
	VkWriteDescriptorSet writes[5];

	// Point this frame's descriptor set at its current resized buffers and image
	memset(writes, 0, sizeof(writes));
	for (uint32_t i=0; i < 4; i++)
	{
		writes[i].sType=VK_STRUCTURE_TYPE_WRITE_DESCRIPTOR_SET;
		writes[i].dstSet=frame->descriptor_set;
		writes[i].dstBinding=i;
		writes[i].descriptorCount=1;
		writes[i].descriptorType=VK_DESCRIPTOR_TYPE_STORAGE_BUFFER;
		writes[i].pBufferInfo=&buffer_info[i];
	}
	writes[4].sType=VK_STRUCTURE_TYPE_WRITE_DESCRIPTOR_SET;
	writes[4].dstSet=frame->descriptor_set;
	writes[4].dstBinding=4;
	writes[4].descriptorCount=1;
	writes[4].descriptorType=VK_DESCRIPTOR_TYPE_STORAGE_IMAGE;
	writes[4].pImageInfo=&image_info;
	vkUpdateDescriptorSets(fb->vk.device, 5, writes, 0, NULL);
}

static VkResult vk_prepare_frame_buffers(vk_frame_t *frame, VkDeviceSize dirty_size)
{
	VkResult ret;
	VkDeviceSize drawq_size=fb->drawq_data[DQ_END]*sizeof(int32_t);
	VkDeviceSize sector_size=fb->sectors*sizeof(int32_t);
	VkDeviceSize entry_size=fb->entry_list_end*sizeof(int32_t);

	// Grow mapped per-frame inputs only when the current compiled lists require it
	ret = vk_ensure_host_buffer(&frame->drawq, drawq_size, VK_BUFFER_USAGE_STORAGE_BUFFER_BIT);
	VK_ERR_RET("vk_ensure_host_buffer(drawq)", ret);
	ret = vk_ensure_host_buffer(&frame->sector_pos, sector_size, VK_BUFFER_USAGE_STORAGE_BUFFER_BIT);
	VK_ERR_RET("vk_ensure_host_buffer(sector_pos)", ret);
	ret = vk_ensure_host_buffer(&frame->entry_list, entry_size, VK_BUFFER_USAGE_STORAGE_BUFFER_BIT);
	VK_ERR_RET("vk_ensure_host_buffer(entry_list)", ret);
	if (dirty_size)
	{
		ret = vk_ensure_host_buffer(&frame->staging, dirty_size, VK_BUFFER_USAGE_TRANSFER_SRC_BIT);
		VK_ERR_RET("vk_ensure_host_buffer(staging)", ret);
	}

	// Copy compiled CPU lists into this fence-protected slot
	memcpy(frame->drawq.mapped, fb->drawq_data, drawq_size);
	memcpy(frame->sector_pos.mapped, fb->sector_pos, sector_size);
	memcpy(frame->entry_list.mapped, fb->entry_list, entry_size);
	vk_update_descriptors(frame);
	return VK_SUCCESS;
}

static void vk_record_input_barriers(VkCommandBuffer command_buffer, vk_frame_t *frame, int copied_resource_data)
{
	VkBufferMemoryBarrier barriers[4];
	uint32_t barrier_count=3;

	// Make coherent host writes to the compiled lists visible to compute reads
	memset(barriers, 0, sizeof(barriers));
	vk_buffer_t *host_buffers[3] = { &frame->drawq, &frame->sector_pos, &frame->entry_list };
	for (uint32_t i=0; i < 3; i++)
	{
		barriers[i].sType=VK_STRUCTURE_TYPE_BUFFER_MEMORY_BARRIER;
		barriers[i].srcAccessMask=VK_ACCESS_HOST_WRITE_BIT;
		barriers[i].dstAccessMask=VK_ACCESS_SHADER_READ_BIT;
		barriers[i].srcQueueFamilyIndex=VK_QUEUE_FAMILY_IGNORED;
		barriers[i].dstQueueFamilyIndex=VK_QUEUE_FAMILY_IGNORED;
		barriers[i].buffer=host_buffers[i]->buffer;
		barriers[i].offset=0;
		barriers[i].size=VK_WHOLE_SIZE;
	}

	// Make an optional staging copy visible to shader resource reads
	if (copied_resource_data)
	{
		barriers[3].sType=VK_STRUCTURE_TYPE_BUFFER_MEMORY_BARRIER;
		barriers[3].srcAccessMask=VK_ACCESS_TRANSFER_WRITE_BIT;
		barriers[3].dstAccessMask=VK_ACCESS_SHADER_READ_BIT;
		barriers[3].srcQueueFamilyIndex=VK_QUEUE_FAMILY_IGNORED;
		barriers[3].dstQueueFamilyIndex=VK_QUEUE_FAMILY_IGNORED;
		barriers[3].buffer=fb->vk.resource_data.buffer;
		barriers[3].offset=0;
		barriers[3].size=VK_WHOLE_SIZE;
		barrier_count++;
	}
	vkCmdPipelineBarrier(command_buffer, copied_resource_data ? VK_PIPELINE_STAGE_TRANSFER_BIT | VK_PIPELINE_STAGE_HOST_BIT : VK_PIPELINE_STAGE_HOST_BIT, VK_PIPELINE_STAGE_COMPUTE_SHADER_BIT, 0, 0, NULL, barrier_count, barriers, 0, NULL);
}

static void vk_collect_frame_timestamps(vk_frame_t *frame)
{
	uint64_t timestamp[2], mask, work_ticks;
	frame_timing_t *timing;
	VkResult ret;

	// Read completed queries only after this slot's fence has signalled
	if (!frame->timestamp_results_pending || !frame->timestamp_pool)
		return;
	ret=vkGetQueryPoolResults(fb->vk.device, frame->timestamp_pool, 0, 2, sizeof(timestamp), timestamp, sizeof(timestamp[0]), VK_QUERY_RESULT_64_BIT);
	frame->timestamp_results_pending=0;
	if (ret!=VK_SUCCESS || frame->timing_index >= fb->timing_count)
		return;

	// Convert the complete compute-through-blit interval like OpenCL event profiling
	mask = fb->vk.timestamp_valid_bits >= 64 ? UINT64_MAX : (UINT64_C(1) << fb->vk.timestamp_valid_bits)-1;
	work_ticks = (timestamp[1]-timestamp[0]) & mask;
	timing = &fb->timing[frame->timing_index];
	timing->thread_start = timing->cl_enqueue_end;
	timing->thread_end = timing->cl_enqueue_end + work_ticks*fb->vk.timestamp_period*1e-9;
}

int vk_drawq_run()
{
	VkResult ret;
	vk_frame_t *frame;
	uint32_t image_index;
	size_t dirty_start=0, dirty_end=0, dirty_size=0;
	VkCommandBuffer command_buffer;

	// Skip zero-sized surfaces while a window is minimised
	if (!fb->vk.initialised || fb->w<=0 || fb->h<=0)
		return 1;

	// Recreate presentation resources after resize or surface invalidation
	if (fb->vk.swapchain_dirty)
	{
		vkDeviceWaitIdle(fb->vk.device);
		ret=vk_create_swapchain();
		if (ret==VK_NOT_READY)
			return 1;
		if (ret!=VK_SUCCESS)
			return 0;
	}
	frame=&fb->vk.frame[fb->vk.frame_index];

	// Wait for every resource owned by this frame slot to become reusable
	double slot_wait_start=get_time_hr();
	ret=vkWaitForFences(fb->vk.device, 1, &frame->fence, VK_TRUE, UINT64_MAX);
	if (ret!=VK_SUCCESS)
		return 0;
	double slot_wait_end=get_time_hr();
	vk_collect_frame_timestamps(frame);
	ret=vkAcquireNextImageKHR(fb->vk.device, fb->vk.swapchain, UINT64_MAX, frame->image_available, VK_NULL_HANDLE, &image_index);
	double acquire_end=get_time_hr();
	// Average waits by reusable frame slot during an explicit diagnostic run
	if (getenv("RL_VK_SLOT_PROBE"))
	{
		static double slot_wait[RL_VK_FRAMES_IN_FLIGHT]={0}, acquire_wait[RL_VK_FRAMES_IN_FLIGHT]={0};
		static int sample_count[RL_VK_FRAMES_IN_FLIGHT]={0};
		uint32_t slot=fb->vk.frame_index;
		slot_wait[slot] += slot_wait_end-slot_wait_start;
		acquire_wait[slot] += acquire_end-slot_wait_end;
		if (++sample_count[slot]==120)
		{
			fprintf_rl(stderr, "Vulkan slot %u: fence %.3f ms acquire %.3f ms\n", slot, slot_wait[slot]*1000./sample_count[slot], acquire_wait[slot]*1000./sample_count[slot]);
			slot_wait[slot]=acquire_wait[slot]=0.; sample_count[slot]=0;
		}
	}
	if (ret==VK_ERROR_OUT_OF_DATE_KHR)
	{
		fb->vk.swapchain_dirty=1;
		return vk_drawq_run();
	}
	if (ret!=VK_SUCCESS && ret!=VK_SUBOPTIMAL_KHR)
		return 0;
	if (ret==VK_SUBOPTIMAL_KHR)
		fb->vk.swapchain_dirty=1;

	// Align and clamp the accumulated packed-resource upload interval
	if (fb->vk.dirty_start!=SIZE_MAX && fb->vk.dirty_end > fb->vk.dirty_start)
	{
		dirty_start=fb->vk.dirty_start & ~(size_t) 3;
		dirty_end=MINN((fb->vk.dirty_end+3) & ~(size_t) 3, fb->data_cl_as);
		dirty_size=dirty_end-dirty_start;
	}
	ret=vk_prepare_frame_buffers(frame, dirty_size);
	if (ret!=VK_SUCCESS)
		return 0;
	if (dirty_size)
		memcpy(frame->staging.mapped, &fb->data[dirty_start], dirty_size);
	// End the copy interval immediately after the actual host memory copies
	fb->timing[fb->timing_index].cl_copy_end=get_time_hr();

	// Reset synchronization only after every fallible CPU preparation step succeeded
	vkResetFences(fb->vk.device, 1, &frame->fence);
	vkResetCommandBuffer(frame->command_buffer, 0);
	command_buffer=frame->command_buffer;
	VkCommandBufferBeginInfo begin_info = { .sType=VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO, .flags=VK_COMMAND_BUFFER_USAGE_ONE_TIME_SUBMIT_BIT };
	ret=vkBeginCommandBuffer(command_buffer, &begin_info);
	if (ret!=VK_SUCCESS)
		return 0;
	if (frame->timestamp_pool)
		vkCmdResetQueryPool(command_buffer, frame->timestamp_pool, 0, 2);

	// Upload the dirty asset interval before interpreting this frame's queue
	if (dirty_size)
	{
		VkBufferCopy copy = { .srcOffset=0, .dstOffset=dirty_start, .size=dirty_size };
		vkCmdCopyBuffer(command_buffer, frame->staging.buffer, fb->vk.resource_data.buffer, 1, &copy);
	}
	vk_record_input_barriers(command_buffer, frame, dirty_size!=0);

	// Transition this slot's output from its previous transfer use into compute storage
	VkImageMemoryBarrier output_to_compute = { .sType=VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER, .srcAccessMask=frame->output_layout_initialised ? VK_ACCESS_TRANSFER_READ_BIT : 0, .dstAccessMask=VK_ACCESS_SHADER_WRITE_BIT, .oldLayout=frame->output_layout_initialised ? VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL : VK_IMAGE_LAYOUT_UNDEFINED, .newLayout=VK_IMAGE_LAYOUT_GENERAL, .srcQueueFamilyIndex=VK_QUEUE_FAMILY_IGNORED, .dstQueueFamilyIndex=VK_QUEUE_FAMILY_IGNORED, .image=frame->output_image, .subresourceRange={VK_IMAGE_ASPECT_COLOR_BIT,0,1,0,1} };
	vkCmdPipelineBarrier(command_buffer, frame->output_layout_initialised ? VK_PIPELINE_STAGE_TRANSFER_BIT : VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT, VK_PIPELINE_STAGE_COMPUTE_SHADER_BIT, 0, 0, NULL, 0, NULL, 1, &output_to_compute);

	// Dispatch one shader invocation for each eight-by-eight tile covering the framebuffer
	vk_drawq_constants_t constants = { fb->w, fb->h, fb->sector_w, fb->sector_size, rand32() };
	vkCmdBindPipeline(command_buffer, VK_PIPELINE_BIND_POINT_COMPUTE, fb->vk.compute_pipeline);
	if (frame->timestamp_pool)
		vkCmdWriteTimestamp(command_buffer, VK_PIPELINE_STAGE_COMPUTE_SHADER_BIT, frame->timestamp_pool, 0);
	vkCmdBindDescriptorSets(command_buffer, VK_PIPELINE_BIND_POINT_COMPUTE, fb->vk.pipeline_layout, 0, 1, &frame->descriptor_set, 0, NULL);
	vkCmdPushConstants(command_buffer, fb->vk.pipeline_layout, VK_SHADER_STAGE_COMPUTE_BIT, 0, sizeof(constants), &constants);
	vkCmdDispatch(command_buffer, ceil_rshift(fb->w, 3), ceil_rshift(fb->h, 3), 1);

	// Make the completed compute image readable by the transfer engine

	VkImageMemoryBarrier output_to_transfer = { .sType=VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER, .srcAccessMask=VK_ACCESS_SHADER_WRITE_BIT, .dstAccessMask=VK_ACCESS_TRANSFER_READ_BIT, .oldLayout=VK_IMAGE_LAYOUT_GENERAL, .newLayout=VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL, .srcQueueFamilyIndex=VK_QUEUE_FAMILY_IGNORED, .dstQueueFamilyIndex=VK_QUEUE_FAMILY_IGNORED, .image=frame->output_image, .subresourceRange={VK_IMAGE_ASPECT_COLOR_BIT,0,1,0,1} };
	vkCmdPipelineBarrier(command_buffer, VK_PIPELINE_STAGE_COMPUTE_SHADER_BIT, VK_PIPELINE_STAGE_TRANSFER_BIT, 0, 0, NULL, 0, NULL, 1, &output_to_transfer);

	// Discard the acquired swapchain contents and prepare them as a blit destination
	VkImageMemoryBarrier swap_to_transfer = { .sType=VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER, .srcAccessMask=0, .dstAccessMask=VK_ACCESS_TRANSFER_WRITE_BIT, .oldLayout=VK_IMAGE_LAYOUT_UNDEFINED, .newLayout=VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, .srcQueueFamilyIndex=VK_QUEUE_FAMILY_IGNORED, .dstQueueFamilyIndex=VK_QUEUE_FAMILY_IGNORED, .image=fb->vk.swapchain_images[image_index], .subresourceRange={VK_IMAGE_ASPECT_COLOR_BIT,0,1,0,1} };
	vkCmdPipelineBarrier(command_buffer, VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT, VK_PIPELINE_STAGE_TRANSFER_BIT, 0, 0, NULL, 0, NULL, 1, &swap_to_transfer);

	// Scale the active framebuffer rectangle to the current drawable surface
	VkImageBlit blit = { .srcSubresource={VK_IMAGE_ASPECT_COLOR_BIT,0,0,1}, .srcOffsets={{0,0,0},{fb->w,fb->h,1}}, .dstSubresource={VK_IMAGE_ASPECT_COLOR_BIT,0,0,1}, .dstOffsets={{0,0,0},{(int32_t) fb->vk.swapchain_extent.width,(int32_t) fb->vk.swapchain_extent.height,1}} };
	vkCmdBlitImage(command_buffer, frame->output_image, VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL, fb->vk.swapchain_images[image_index], VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 1, &blit, VK_FILTER_NEAREST);


	// Mark completion of the complete GPU workload
	if (frame->timestamp_pool)
		vkCmdWriteTimestamp(command_buffer, VK_PIPELINE_STAGE_TRANSFER_BIT, frame->timestamp_pool, 1);

	// Hand the fully written swapchain image back to the presentation engine
	VkImageMemoryBarrier swap_to_present = { .sType=VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER, .srcAccessMask=VK_ACCESS_TRANSFER_WRITE_BIT, .dstAccessMask=0, .oldLayout=VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, .newLayout=VK_IMAGE_LAYOUT_PRESENT_SRC_KHR, .srcQueueFamilyIndex=VK_QUEUE_FAMILY_IGNORED, .dstQueueFamilyIndex=VK_QUEUE_FAMILY_IGNORED, .image=fb->vk.swapchain_images[image_index], .subresourceRange={VK_IMAGE_ASPECT_COLOR_BIT,0,1,0,1} };
	vkCmdPipelineBarrier(command_buffer, VK_PIPELINE_STAGE_TRANSFER_BIT, VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT, 0, 0, NULL, 0, NULL, 1, &swap_to_present);
	ret=vkEndCommandBuffer(command_buffer);
	if (ret!=VK_SUCCESS)
		return 0;

	// Let compute execute early while acquisition gates only the transfer stage
	VkPipelineStageFlags wait_stage=VK_PIPELINE_STAGE_TRANSFER_BIT;
	VkSubmitInfo submit_info = { .sType=VK_STRUCTURE_TYPE_SUBMIT_INFO, .waitSemaphoreCount=1, .pWaitSemaphores=&frame->image_available, .pWaitDstStageMask=&wait_stage, .commandBufferCount=1, .pCommandBuffers=&command_buffer, .signalSemaphoreCount=1, .pSignalSemaphores=&frame->render_finished };
	ret=vkQueueSubmit(fb->vk.queue, 1, &submit_info, frame->fence);
	if (ret!=VK_SUCCESS)
		return 0;
	// Associate timestamp results with the timing slot for this submitted frame
	if (frame->timestamp_pool)
	{
		frame->timing_index=fb->timing_index;
		frame->timestamp_results_pending=1;
	}
	// End backend enqueue timing before the potentially pacing presentation call
	fb->timing[fb->timing_index].cl_enqueue_end=get_time_hr();

	// Queue FIFO presentation and defer resize recovery until the next frame
	VkPresentInfoKHR present_info = { .sType=VK_STRUCTURE_TYPE_PRESENT_INFO_KHR, .waitSemaphoreCount=1, .pWaitSemaphores=&frame->render_finished, .swapchainCount=1, .pSwapchains=&fb->vk.swapchain, .pImageIndices=&image_index };
	ret=vkQueuePresentKHR(fb->vk.queue, &present_info);
	if (ret==VK_ERROR_OUT_OF_DATE_KHR || ret==VK_SUBOPTIMAL_KHR)
		fb->vk.swapchain_dirty=1;
	else if (ret!=VK_SUCCESS)
		return 0;

	// Commit frame ownership and clear the uploaded dirty interval
	frame->output_layout_initialised=1;
	fb->vk.dirty_start=SIZE_MAX;
	fb->vk.dirty_end=0;
	fb->vk.frame_index=(fb->vk.frame_index+1)%RL_VK_FRAMES_IN_FLIGHT;
	return 1;
}

int vk_init()
{
	VkResult ret;
	VkFormatProperties output_properties, swapchain_properties;

	// Start from an empty state so partial initialization can share teardown
	memset(&fb->vk, 0, sizeof(fb->vk));
	fb->vk.dirty_start=SIZE_MAX;
	ret=vk_create_instance_surface();
	if (ret!=VK_SUCCESS)
		goto fail;
	ret=vk_select_device();
	if (ret!=VK_SUCCESS)
		goto fail;
	ret=vk_create_swapchain();
	if (ret!=VK_SUCCESS)
		goto fail;

	// Require storage output and nearest blits for the selected formats
	vkGetPhysicalDeviceFormatProperties(fb->vk.gpu, VK_FORMAT_R8G8B8A8_UNORM, &output_properties);
	vkGetPhysicalDeviceFormatProperties(fb->vk.gpu, fb->vk.swapchain_format, &swapchain_properties);
	if (!(output_properties.optimalTilingFeatures & VK_FORMAT_FEATURE_STORAGE_IMAGE_BIT) || !(output_properties.optimalTilingFeatures & VK_FORMAT_FEATURE_BLIT_SRC_BIT) || !(swapchain_properties.optimalTilingFeatures & VK_FORMAT_FEATURE_BLIT_DST_BIT))
	{
		ret=VK_ERROR_FORMAT_NOT_SUPPORTED;
		goto fail;
	}

	// Create the shader pipeline and all independently reusable frame slots
	ret=vk_create_pipeline();
	if (ret!=VK_SUCCESS)
		goto fail;
	ret=vk_create_frames();
	if (ret!=VK_SUCCESS)
		goto fail;
	fb->vk.initialised=1;
	return VK_SUCCESS;

fail:
	// Release every object created before the failed initialization step
	fprintf_rl(stderr, "vk_init() failed: %s\n", get_vk_error_string(ret));
	vk_deinit();
	return ret;
}

void vk_deinit()
{
	// Finish the small set of in-flight frames before reversing ownership
	if (fb->vk.device)
		vkDeviceWaitIdle(fb->vk.device);

	for (int i=0; i < RL_VK_FRAMES_IN_FLIGHT; i++)
	{
		vk_frame_t *frame=&fb->vk.frame[i];

		// Release per-frame mapped inputs, output images, and synchronization
		if (fb->vk.device)
		{
			vk_destroy_buffer(&frame->staging);
			vk_destroy_buffer(&frame->drawq);
			vk_destroy_buffer(&frame->sector_pos);
			vk_destroy_buffer(&frame->entry_list);
			if (frame->output_view)
				vkDestroyImageView(fb->vk.device, frame->output_view, NULL);
			if (frame->output_image)
				vkDestroyImage(fb->vk.device, frame->output_image, NULL);
			if (frame->output_memory)
				vkFreeMemory(fb->vk.device, frame->output_memory, NULL);
			if (frame->image_available)
				vkDestroySemaphore(fb->vk.device, frame->image_available, NULL);
			if (frame->render_finished)
				vkDestroySemaphore(fb->vk.device, frame->render_finished, NULL);
			if (frame->fence)
				vkDestroyFence(fb->vk.device, frame->fence, NULL);
			if (frame->timestamp_pool)
				vkDestroyQueryPool(fb->vk.device, frame->timestamp_pool, NULL);
		}
	}

	// Release shared compute, descriptor, data, and swapchain resources
	if (fb->vk.device)
	{
		vk_destroy_buffer(&fb->vk.resource_data);
		if (fb->vk.compute_pipeline)
			vkDestroyPipeline(fb->vk.device, fb->vk.compute_pipeline, NULL);
		if (fb->vk.pipeline_layout)
			vkDestroyPipelineLayout(fb->vk.device, fb->vk.pipeline_layout, NULL);
		if (fb->vk.descriptor_pool)
			vkDestroyDescriptorPool(fb->vk.device, fb->vk.descriptor_pool, NULL);
		if (fb->vk.descriptor_layout)
			vkDestroyDescriptorSetLayout(fb->vk.device, fb->vk.descriptor_layout, NULL);
		vk_destroy_swapchain();
		if (fb->vk.command_pool)
			vkDestroyCommandPool(fb->vk.device, fb->vk.command_pool, NULL);
		vkDestroyDevice(fb->vk.device, NULL);
	}

	// Release the window surface and instance last, then permit clean reinitialization
	if (fb->vk.surface && fb->vk.instance)
		vkDestroySurfaceKHR(fb->vk.instance, fb->vk.surface, NULL);
	if (fb->vk.instance)
		vkDestroyInstance(fb->vk.instance, NULL);
	memset(&fb->vk, 0, sizeof(fb->vk));
}

#endif
